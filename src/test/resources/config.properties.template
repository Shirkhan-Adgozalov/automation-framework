# Saucedemo Configuration Template
# Copy this file to config.properties and modify as needed

# Supported browsers: chrome, firefox, edge, safari (macOS only)
# NOTE: Safari automatically falls back to Chrome in CI/CD environments (Linux)
baseUrl=https://www.saucedemo.com/
browser=chrome
headless=false

# Development settings (macOS - all browsers supported)
# browser=chrome
# headless=false

# Production settings (CI/CD - headless Chrome recommended)
# browser=chrome
# headless=true

# macOS Safari settings (Headless not fully supported)
# browser=safari
# headless=false

# Firefox settings
# browser=firefox
# headless=true

# Edge settings
# browser=edge
# headless=true

# CI/CD Environment Notes:
# - Safari automatically falls back to Chrome on Linux
# - Use headless=true for faster CI/CD execution
# - Chrome is recommended for CI/CD pipelines
